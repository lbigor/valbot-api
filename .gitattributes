# Normalização de fim-de-linha — mantém LF em código fonte, evita conflitos
# entre macOS/Linux e Windows. Binários ficam intocados.

* text=auto eol=lf

# Código fonte (LF obrigatório)
*.py        text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.toml      text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.sql       text eol=lf
*.sh        text eol=lf
Dockerfile  text eol=lf
Makefile    text eol=lf

# Binários (sem normalização, sem diff visual)
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.webp      binary
*.svg       text
*.ico       binary
*.pdf       binary
*.mp4       binary
*.mov       binary
*.zip       binary
*.gz        binary
*.tar       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.otf       binary

# Arquivos gerados — ignorar do diff por padrão
pnpm-lock.yaml   linguist-generated
package-lock.json linguist-generated
*.lock           linguist-generated
