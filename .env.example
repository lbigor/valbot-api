# =============================================================================
# .env.example — copie para `.env` em /opt/valbot-deploy/ na VM e preencha.
# NUNCA commit este arquivo já preenchido.
# =============================================================================

# Postgres local da VM (containerizado).
POSTGRES_PASSWORD=__gerar_via_openssl_rand_base64_32__

# Imagem Docker — em produção use SHA específico (não `latest`).
IMAGE_TAG=latest
GCP_PROJECT=project-308f1fa8-a301-49e6-a69

# Mock VLM — defina 1 para usar resultado fake (dev sem créditos GCP).
# Em produção SEMPRE 0.
VALBOT_USE_MOCK_VLM=0

# Caddy — domínio servido com TLS Let's Encrypt automático.
# Definido no caddy/Caddyfile. Ajustar lá se mudar de domínio.

# Admin token — protege os endpoints /api/admin/* (header X-Admin-Token).
VALBOT_ADMIN_TOKEN=__gerar_via_openssl_rand_hex_32__

# =============================================================================
# AWS S3 — credenciais para baixar vídeos de exame de buckets S3 PRIVADOS.
# O backend é Python e usa o AWS SDK boto3 (não o SDK Java).
# Crie uma chave IAM DEDICADA com permissão MÍNIMA `s3:GetObject` no bucket
# dos vídeos. NUNCA commit os valores reais (protegido por .gitignore+gitleaks).
# =============================================================================
AWS_ACCESS_KEY_ID=__sua_access_key_id__
AWS_SECRET_ACCESS_KEY=__sua_secret_access_key__
AWS_REGION=us-east-1
# Bucket padrão dos vídeos (opcional — pode vir embutido na URL s3://bucket/key).
AWS_S3_BUCKET=
